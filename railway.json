{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "context": "./backend"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "npx prisma migrate deploy && node dist/src/main.js",
    "sleepApplication": false,
    "useLegacyStacker": false,
    "ipv6EgressEnabled": false,
    "multiRegionConfig": {
      "europe-west4-drams3a": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  },
  "env": {
    "PORT": {
      "description": "Server port",
      "value": "3000"
    },
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    },
    "JWT_SECRET": {
      "description": "JWT secret for token signing",
      "required": true
    },
    "JWT_EXPIRATION": {
      "description": "JWT token expiration time",
      "value": "24h"
    },
    "DATABASE_URL": {
      "description": "PostgreSQL connection string",
      "required": true
    },
    "ADMIN_PANEL_URL": {
      "description": "Admin panel frontend URL",
      "required": true
    },
    "INITIAL_ADMIN_USER": {
      "description": "Initial admin email for seed",
      "value": "carlos_admin"
    },
    "INITIAL_ADMIN_PASS": {
      "description": "Initial admin password for seed",
      "required": true
    }
  }
}
